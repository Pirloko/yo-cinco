# Copia este archivo a `.env.local` y rellena los valores (Supabase Dashboard → Settings → API).
# En Netlify: Site settings → Environment variables (mismas claves).

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key

# URL pública de la app (sin barra final). En producción (Netlify/Vercel) pon tu dominio real;
# evita dejar localhost aquí o el login con Google redirigirá mal.
# NEXT_PUBLIC_SITE_URL=https://tu-dominio.com

# Zona horaria para mostrar fechas/horas de partidos (IANA). Por defecto: Chile.
# NEXT_PUBLIC_APP_TIMEZONE=America/Santiago

# Opcional: solo en servidor (páginas públicas equipo/revuelta que lean datos con service role).
# NO expongas esta clave en el cliente ni en variables NEXT_PUBLIC_*.
# SUPABASE_SERVICE_ROLE_KEY=
