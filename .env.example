# Copia este archivo a `.env.local` y rellena los valores (Supabase Dashboard → Settings → API).
# En Netlify: Site settings → Environment variables (mismas claves).

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key

# Opcional: solo en servidor (páginas públicas equipo/revuelta que lean datos con service role).
# NO expongas esta clave en el cliente ni en variables NEXT_PUBLIC_*.
# SUPABASE_SERVICE_ROLE_KEY=
